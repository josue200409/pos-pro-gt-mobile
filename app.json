{
  "expo": {
    "name": "POS Pro GT",
    "slug": "pos-pro-gt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a56db"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a56db"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.mazariegos2004.posprogt"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-sharing",
      "expo-router"
      
    ],
    "extra": {
      "eas": {
        "projectId": "da949fbf-7820-4d9d-9513-2327ff6e6cc8"
      }
    }
  }
}
